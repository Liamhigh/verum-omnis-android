<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_verum_space"
    android:fitsSystemWindows="true"
    android:paddingLeft="16dp"
    android:paddingTop="12dp"
    android:paddingRight="16dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_glass_panel"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/gemmaTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Gemma"
                android:textColor="@color/pure_white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/gemmaBackBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingLeft="14dp"
                android:paddingTop="8dp"
                android:paddingRight="14dp"
                android:paddingBottom="8dp"
                android:text="Back"
                android:textAllCaps="false"
                android:textColor="@color/pure_white"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/gemmaNewChatBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:text="New Chat"
                android:textAllCaps="false"
                android:textColor="@color/pure_white"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button" />

            <Button
                android:id="@+id/gemmaHistoryBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:text="History"
                android:textAllCaps="false"
                android:textColor="@color/pure_white"
                android:textStyle="bold"
                android:background="@drawable/bg_secondary_button" />
        </LinearLayout>

        <TextView
            android:id="@+id/gemmaCaseBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_gemma_chip"
            android:maxLines="2"
            android:paddingLeft="10dp"
            android:paddingTop="8dp"
            android:paddingRight="10dp"
            android:paddingBottom="8dp"
            android:textColor="@color/pure_white"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/gemmaScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_glass_panel"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/gemmaMessagesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_panel"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:padding="10dp">

        <EditText
            android:id="@+id/gemmaInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:gravity="top"
            android:hint="Ask about the case or draft a sealed legal email"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="5"
            android:minHeight="52dp"
            android:textColor="@color/pure_white"
            android:textColorHint="@color/verum_text_soft" />

        <Button
            android:id="@+id/gemmaSendBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="Send"
            android:textAllCaps="false"
            android:textColor="@color/pure_white"
            android:textStyle="bold"
            android:background="@drawable/bg_primary_button" />
    </LinearLayout>

</LinearLayout>
