<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_verum_space"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingTop="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_verum_home_banner" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gemma_chip"
                android:paddingLeft="12dp"
                android:paddingTop="6dp"
                android:paddingRight="12dp"
                android:paddingBottom="6dp"
                android:text="@string/home_start_kicker"
                android:textAllCaps="true"
                android:textColor="@color/verum_gold"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/heroHeadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:textColor="@color/pure_white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/heroSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/hero_summary"
                android:textColor="@color/verum_text_soft"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/selectedFileLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/selected_file_label"
                android:textColor="@color/pure_white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/selectedFileValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:text="@string/no_file_selected"
                android:textColor="@color/verum_text_soft"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/legalAdvisoryToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:buttonTint="@color/verum_gold"
                android:checked="false"
                android:text="@string/include_legal_advisory"
                android:textColor="@color/pure_white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/legalAdvisoryHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/include_legal_advisory_hint"
                android:textColor="@color/verum_text_soft"
                android:textSize="12sp" />

            <Button
                android:id="@+id/selectBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_primary_button"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/action_select_file"
                android:textColor="@color/pure_white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/sealBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="@string/action_seal_document"
                    android:textColor="@color/pure_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/verifyQrBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="@string/action_scan_verify"
                    android:textColor="@color/pure_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/vaultBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="@string/action_open_vault"
                    android:textColor="@color/pure_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/gemmaBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_secondary_button"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:text="@string/action_open_gemma"
                    android:textColor="@color/pure_white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/constitutionBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_secondary_button"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="@string/action_view_constitution"
                android:textColor="@color/pure_white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/video_intro_title"
                android:textColor="@color/pure_white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="14dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/video_intro_body"
                android:textColor="@color/verum_text_soft"
                android:textSize="14sp" />

            <VideoView
                android:id="@+id/introVideoView"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="12dp"
                android:background="#22000000" />

            <Button
                android:id="@+id/introVideoButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_secondary_button"
                android:text="@string/loading_intro_video"
                android:textColor="@color/pure_white"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_how_it_works"
                android:textColor="@color/pure_white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/boundaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/verum_text_soft"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_architecture"
                android:textColor="@color/pure_white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/constitutionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/verum_text_soft"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_sealing"
                android:textColor="@color/pure_white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/businessModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="16dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/verum_text_soft"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/caseStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/verum_gold"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_glass_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_gemma"
                android:textColor="@color/pure_white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/gemmaStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/verum_text_soft"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/footerLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/footer_line"
            android:textColor="@color/verum_text_soft"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
